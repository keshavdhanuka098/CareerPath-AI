# CareerPath AI Environment Variables

# Google Gemini API (optional — falls back to curated local data if unset)
GEMINI_API_KEY=

# MongoDB connection string (required)
# Local example:  mongodb://127.0.0.1:27017/careerpath-ai
# Atlas example:  mongodb+srv://<user>:<password>@cluster0.mongodb.net/careerpath-ai
MONGODB_URI=

# Security & Secrets
# Generate a strong random value for production, e.g.: openssl rand -hex 32
JWT_SECRET=super-secret-careerpath-key-12345

# The public URL of this site. Used for CORS and building password-reset links.
CLIENT_URL=http://localhost:3000

# Set to "production" when deploying. Enables secure (HTTPS-only) cookies.
NODE_ENV=development

# Optional SMTP Settings for Nodemailer (registration + password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
